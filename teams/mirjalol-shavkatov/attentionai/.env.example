# API Keys for Language Model providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Legacy streamlit admin password (optional)
ADMIN_PASSWORD=admin123

# === Production Auth & Authorization (FastAPI & React Dashboard) ===
# Google OAuth2 credentials from Google Cloud Console (https://console.cloud.google.com)
# Ensure authorized redirect URIs match your backend, and JavaScript origins match your dashboard.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cryptographically secure random JWT Secret Key (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=generate_a_cryptographically_secure_hex_key_here

# Initial super admin email to seed the database allowlist
INITIAL_ADMIN_EMAIL=your_email@gmail.com

# Dashboard base URL for CORS/Cookie settings
DASHBOARD_URL=http://localhost:5173
